{
  "systemsimVersion": "1.0",
  "metadata": {
    "name": "Resilience Showcase",
    "source": "Demonstrates circuit breakers, retry storms, and backpressure working together",
    "tags": ["resilience", "circuit-breaker", "retry", "backpressure", "phase-3"]
  },
  "nodes": [
    {
      "type": "load_balancer",
      "label": "Edge LB",
      "config": { "algorithm": "round-robin", "isEntry": true }
    },
    {
      "type": "api_gateway",
      "label": "API Gateway",
      "config": {
        "rateLimitRps": 60,
        "authMiddleware": "jwt"
      }
    },
    {
      "type": "server",
      "label": "API Server",
      "config": {
        "instanceCount": 3,
        "processingTimeMs": 15,
        "maxConcurrent": 1000,
        "retryPolicy": { "maxRetries": 3, "backoffMs": 100, "backoffMultiplier": 2 }
      }
    },
    {
      "type": "database",
      "label": "Primary DB",
      "config": {
        "engine": "postgres",
        "writeThroughputRps": 5,
        "readThroughputRps": 5,
        "readReplicas": 0,
        "connectionPoolSize": 30,
        "backpressure": { "enabled": true }
      }
    }
  ],
  "edges": [
    {
      "source": "load_balancer-0",
      "target": "api_gateway-1",
      "config": {
        "latencyMs": 5,
        "jitterMs": 2,
        "throughputRps": 100000,
        "circuitBreaker": {
          "failureThreshold": 0.3,
          "failureWindow": 5,
          "cooldownSeconds": 8,
          "halfOpenTicks": 2
        }
      }
    },
    { "source": "api_gateway-1", "target": "server-2" },
    { "source": "server-2", "target": "database-3" }
  ],
  "starter": {
    "trafficProfile": {
      "profileName": "DB overload drill",
      "durationSeconds": 60,
      "phases": [
        { "startS": 0, "endS": 30, "rps": 6, "shape": "steady", "description": "Calm baseline within DB capacity" },
        { "startS": 30, "endS": 60, "rps": 40, "shape": "spike", "description": "Traffic surge buries the tiny DB: backpressure, retries, breaker trips" }
      ],
      "requestMix": { "default": 1.0 },
      "userDistribution": "uniform",
      "jitterPercent": 10
    },
    "schemaMemory": {
      "version": 1,
      "entities": [
        {
          "id": "records",
          "name": "records",
          "fields": [
            { "name": "id", "type": "uuid", "cardinality": "high" },
            { "name": "payload", "type": "text", "cardinality": "high" }
          ],
          "indexes": [{ "field": "id", "type": "btree" }],
          "accessPatterns": [
            { "operation": "read", "frequency": "high", "pattern": "fetch record by id" },
            { "operation": "write", "frequency": "medium", "pattern": "insert record" }
          ],
          "assignedDbId": "database-3"
        }
      ],
      "relationships": [],
      "aiNotes": "Minimal single-table schema; the deliberately tiny DB (5 rps read / 5 rps write) is the failure injection point."
    },
    "apiContracts": [
      { "id": "resilience-get", "method": "GET", "path": "/records/:id", "description": "Read a record through the resilient path", "authMode": "jwt", "ownerServiceId": "server-2" },
      { "id": "resilience-create", "method": "POST", "path": "/records", "description": "Write a record through the resilient path", "authMode": "jwt", "ownerServiceId": "server-2" }
    ]
  }
}
