{
  "systemsimVersion": "1.0",
  "metadata": {
    "name": "Resilience Showcase",
    "source": "Demonstrates circuit breakers, retry storms, and backpressure working together",
    "tags": ["resilience", "circuit-breaker", "retry", "backpressure", "phase-3"]
  },
  "nodes": [
    {
      "type": "load_balancer",
      "label": "Edge LB",
      "config": { "algorithm": "round-robin", "isEntry": true }
    },
    {
      "type": "api_gateway",
      "label": "API Gateway",
      "config": {
        "rateLimitRps": 60,
        "authMiddleware": "jwt"
      }
    },
    {
      "type": "server",
      "label": "API Server",
      "config": {
        "instanceCount": 3,
        "processingTimeMs": 15,
        "maxConcurrent": 1000,
        "retryPolicy": { "maxRetries": 3, "backoffMs": 100, "backoffMultiplier": 2 }
      }
    },
    {
      "type": "database",
      "label": "Primary DB",
      "config": {
        "engine": "postgres",
        "writeThroughputRps": 5,
        "readThroughputRps": 5,
        "readReplicas": 0,
        "connectionPoolSize": 30,
        "backpressure": { "enabled": true }
      }
    }
  ],
  "edges": [
    {
      "source": "load_balancer-0",
      "target": "api_gateway-1",
      "config": {
        "latencyMs": 5,
        "jitterMs": 2,
        "throughputRps": 100000,
        "circuitBreaker": {
          "failureThreshold": 0.3,
          "failureWindow": 5,
          "cooldownSeconds": 8,
          "halfOpenTicks": 2
        }
      }
    },
    { "source": "api_gateway-1", "target": "server-2" },
    { "source": "server-2", "target": "database-3" }
  ]
}
