{
  "systemsimVersion": "1.0",
  "metadata": {
    "name": "Hot Shard",
    "source": "How-to — reproduce a hot-shard (Pareto distribution on user_id)",
    "tags": ["howto", "sharding", "pareto"]
  },
  "nodes": [
    { "type": "load_balancer", "label": "Edge LB", "config": { "isEntry": true } },
    { "type": "server", "label": "App Server", "config": { "instanceCount": 4, "processingTimeMs": 15, "maxConcurrent": 1000 } },
    { "type": "database", "label": "Sharded DB", "config": { "engine": "cassandra", "shardingEnabled": true, "shardCount": 4, "shardKey": "user_id", "writeThroughputRps": 2000, "readThroughputRps": 5000, "connectionPoolSize": 80 } }
  ],
  "edges": [
    { "source": "load_balancer-0", "target": "server-1" },
    { "source": "server-1", "target": "database-2" }
  ]
}
