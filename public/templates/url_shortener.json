{
  "systemsimVersion": "1.0",
  "metadata": {
    "name": "URL Shortener",
    "source": "Based on bit.ly / TinyURL architecture",
    "sourceUrl": "https://blog.bytebytego.com/p/design-a-url-shortener",
    "tags": ["cache", "read-heavy", "simple"]
  },
  "nodes": [
    { "type": "load_balancer", "label": "Load Balancer" },
    { "type": "server", "label": "API Server", "config": { "instanceCount": 2 } },
    { "type": "cache", "label": "URL Cache", "config": { "ttlSeconds": 86400, "evictionPolicy": "lru" } },
    { "type": "database", "label": "URL Store", "config": { "engine": "postgres" } }
  ],
  "edges": [
    { "source": "load_balancer-0", "target": "server-1" },
    { "source": "server-1", "target": "cache-2" },
    { "source": "server-1", "target": "database-3" },
    { "source": "cache-2", "target": "database-3" }
  ],
  "starter": {
    "trafficProfile": {
      "profileName": "Viral link redirect storm",
      "durationSeconds": 60,
      "phases": [
        { "startS": 0, "endS": 40, "rps": 28, "shape": "steady", "description": "Steady redirect traffic, mostly cache hits" },
        { "startS": 40, "endS": 60, "rps": 65, "shape": "spike", "description": "A shortened link goes viral on social media" }
      ],
      "requestMix": { "default": 1.0 },
      "userDistribution": "uniform",
      "jitterPercent": 10
    },
    "schemaMemory": {
      "version": 1,
      "entities": [
        {
          "id": "links",
          "name": "links",
          "fields": [
            { "name": "code", "type": "text", "cardinality": "high" },
            { "name": "target_url", "type": "text", "cardinality": "high" },
            { "name": "created_at", "type": "timestamp", "cardinality": "high" }
          ],
          "indexes": [{ "field": "code", "type": "btree" }],
          "accessPatterns": [
            { "operation": "read", "frequency": "very_high", "pattern": "resolve code to target URL on cache miss" },
            { "operation": "write", "frequency": "low", "pattern": "create new short link" }
          ],
          "assignedDbId": "database-3"
        },
        {
          "id": "clicks",
          "name": "clicks",
          "fields": [
            { "name": "id", "type": "uuid", "cardinality": "high" },
            { "name": "code", "type": "text", "cardinality": "high" },
            { "name": "clicked_at", "type": "timestamp", "cardinality": "high" }
          ],
          "indexes": [{ "field": "code", "type": "btree" }],
          "accessPatterns": [
            { "operation": "write", "frequency": "very_high", "pattern": "append click event per redirect" }
          ],
          "assignedDbId": "database-3"
        }
      ],
      "relationships": [
        { "from": "links", "to": "clicks", "type": "one_to_many" }
      ],
      "aiNotes": "Read-heavy: redirects dominate and are served from the 24h-TTL cache; click analytics are append-only writes."
    },
    "apiContracts": [
      { "id": "shortener-redirect", "method": "GET", "path": "/:code", "description": "Resolve a short code and redirect", "authMode": "jwt", "ownerServiceId": "server-1" },
      { "id": "shortener-create", "method": "POST", "path": "/links", "description": "Create a new short link", "authMode": "jwt", "ownerServiceId": "server-1" }
    ]
  }
}
